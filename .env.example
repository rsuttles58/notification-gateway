# --- API ---
PORT=3000
API_KEY=dev-local-key-change-me
# Pino log level: trace|debug|info|warn|error|fatal. Pretty-printed unless NODE_ENV=production (then JSON).
LOG_LEVEL=info

# --- Postgres ---
# Host port 5433 (docker-compose maps 5433->5432) to avoid clashing with a
# native Postgres already on 5432.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/notifications

# --- Redis (BullMQ + rate limiter) ---
REDIS_URL=redis://localhost:6379

# --- Email (SMTP, e.g. Mailtrap / SendGrid SMTP / Gmail) ---
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Notifications <no-reply@example.com>"

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- SMS rate limits (deliberately very conservative) ---
# Max SMS to a single recipient within the recipient window.
SMS_PER_RECIPIENT_MAX=1
SMS_PER_RECIPIENT_WINDOW_SEC=3600
# Global ceiling across ALL recipients per rolling day.
SMS_GLOBAL_DAILY_MAX=20
# Worker throughput: at most N SMS jobs processed per duration (ms).
SMS_WORKER_MAX_PER_DURATION=1
SMS_WORKER_DURATION_MS=15000
